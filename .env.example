## Configuracion general de la aplicacion ByePaper Intake Engine ##
APP_NAME=ByePaper Intake Engine
# Entorno configurable para el futuro (DEV, TES, UAT, PRD)
ENVIRONMENT=development
#Prefijo para todas las rutas de la API. Facilita la versionamiento de la API 
API_V1_PREFIX=/api/v1

## Base de datos (PostgreSQL) ##
#URL de conexion a la base de datos PostgreSQL. 
#Formato: dialect+driver://username:password@host:port/database
#Nota: Usamos 'db' como host porque Docker COmpose resolverá internamente 
#El driver 'psycopg' es el recomendado para PostgreSQL en Python.
DATABASE_URL=postgresql+psycopg://byepaper:byepaper@db:5432/byepaper

## Cola de tareas y workers (Redis + RQ) ##
#Conexión al broker de mensajes (Redis). Usado para encolar los documentos y procesarlos de manera asíncrona.
REDIS_URL=redis://redis:6379/0
#Nombre de la cola donde el worker escuchará los trabajos de extracción y clasificación de documentos.
RQ_QUEUE_NAME=document-processing

## Almacenamiento de documentos (Storage Adapter) ##
#Define el tipo de almacenamiento
#Valores soportados: 'local' (almacenamiento en disco local), 's3' (Amazon S3)
STORAGE_BACKEND=local
#Ruta interna dentro del contenedor de Docker donde se guardarán los archivos físico. 
#Esta ruta deb e estar montada como un volumen en Docker Compose para persistencia de datos.
LOCAL_STORAGE_PATH=/data/storage

## Validación y seguridad de ingesta ##
#Límite de tamaño por archivo en Megabytes.
MAX_UPLOAD_SIZE_MB=10
#Lista blanca de tipos MIME permitidos para la ingesta de documentos. 
ALLOWED_MIME_TYPES=application/pdf,image/png,image/jpeg,text/plain

## Cors y observabilidad ##
#Orígenes permitidos para el frontend 
#El puerto 5173 es el predeterminado de Vite (React). 
CORS_ORIGINS=http://localhost:5173
#Nivel de detalle de los logs. Valores posibles: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

#Secreto para hash
API_KEY_HASH_SECRET=change-this-secret-in-production

#Límites de upload
MAX_UPLOAD_SIZE_BYTES=10485760
ALLOWED_UPLOAD_MIME_TYPES=application/pdf,image/png,image/jpeg,text/plain
LOCAL_STORAGE_ROOT=data/uploads